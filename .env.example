# ========================================
# TaskBoard Environment Configuration
# ========================================
# Copy this file to .env and fill in your values
# cp .env.example .env

# Environment
NODE_ENV=development

# API Server
API_PORT=3001
JWT_ACCESS_SECRET=change-me-to-a-secure-random-string
JWT_REFRESH_SECRET=change-me-to-another-secure-random-string

# MongoDB
MONGO_URL=mongodb://mongo:27017/taskboard

# RabbitMQ
RABBIT_URL=amqp://rabbitmq:5672

# Redis
REDIS_URL=redis://redis:6379

# Worker Service (internal API URL)
API_URL=http://api:3001

# Frontend (Vite)
VITE_API_URL=http://localhost:3001
VITE_SOCKET_URL=http://localhost:3001

# CORS Origins (comma-separated)
CORS_ORIGINS=http://localhost:5173,http://localhost